# ===========================================
# Web3 Daily Digest - Environment Variables
# ===========================================

# ===========================================
# LLM Configuration (Kimi/Moonshot API)
# ===========================================
# Using Kimi K2 model via Moonshot API
LLM_API_BASE=https://api.moonshot.cn/v1

# Kimi API key
LLM_API_KEY=sk-Nu4nsNqZtsD1cmm1hJG2wrgc0eG1cQXe77bxZ226uolR2Idu

# Primary model for text processing and filtering
# Kimi K2 thinking model for better reasoning
PRIMARY_MODEL=kimi-k2-0711-preview

# Vision-Language model (optional, Kimi supports vision)
VL_MODEL=moonshot-v1-8k-vision-preview

# Concurrent LLM requests limit
LLM_CONCURRENT_NUMBER=3

# ===========================================
# Telegram Bot Configuration
# ===========================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=AAGY5ooxgA3vrGUfsPMkJbvu9LDpml5uJYs

# ===========================================
# Data Directory
# ===========================================
DATA_DIR=./data

# ===========================================
# Push Configuration
# ===========================================
DEFAULT_PUSH_TIME=09:00
DEFAULT_TIMEZONE=Asia/Shanghai

# ===========================================
# RSS Configuration
# ===========================================
FETCH_INTERVAL_HOURS=1
RSS_APP_API_KEY=your_rss_app_key_here

# ===========================================
# Debug and Logging
# ===========================================
DEBUG=false
# VERBOSE=true
