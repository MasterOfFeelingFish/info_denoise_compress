# Environment Configuration for Web3 Daily Digest
# 复制此文件为 .env 并填写你自己的密钥:  cp .env.example .env

# ============================================================================
# 🚀 LLM 配置 - 一键切换
# ============================================================================
# 可选值: gemini | openai
LLM=gemini

# --- Gemini 配置（推荐，免费额度够用）---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_URL=
GEMINI_THINKING_LEVEL=HIGH

# --- OpenAI 配置（兼容 Kimi、DeepSeek 等）---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_API_URL=

# ============================================================================
# 🤖 Telegram Bot 配置
# ============================================================================
# 在 Telegram 找 @BotFather 创建你自己的测试 Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 管理员 Telegram ID（多个用逗号分隔，用 @userinfobot 获取）
ADMIN_TELEGRAM_IDS=123456789

# 白名单开关（debug 时建议设为 false，所有用户可访问）
WHITELIST_ENABLED=false

# ============================================================================
# ⏰ 推送配置
# ============================================================================
PUSH_HOUR=9
PUSH_MINUTE=0

# ============================================================================
# 🐦 Twitter RSS 配置（@用户名自动转 RSS）
# ============================================================================
# 转换服务: rsshub (默认) | nitter | custom
TWITTER_RSS_SERVICE=rsshub

# 服务地址（留空使用默认）
# RSSHub 公共实例: https://rsshub.liumingye.cn (默认)
# RSSHub 自托管: https://your-rsshub.example.com
# Nitter: https://nitter.privacydev.net
# Custom: https://your-service.com/twitter/{username}/rss
TWITTER_RSS_BASE_URL=

# ============================================================================
# 🔄 预抓取配置（解决 RSS.app 只返回最近内容的问题）
# ============================================================================
# 预抓取间隔（小时），建议 1-2 小时
PREFETCH_INTERVAL_HOURS=1

# 预抓取开始时间（小时，北京时间）
PREFETCH_START_HOUR=1

# ============================================================================
# 📊 简报配置
# ============================================================================
# 每日精选输出条数
MAX_DIGEST_ITEMS=25

# 每批处理的新闻数量（超过此数量则分批处理）
BATCH_SIZE=100

# 并发处理用户数（推送简报时同时处理多少用户）
CONCURRENT_USERS=10

# ============================================================================
# 📊 数据管理配置
# ============================================================================
DATA_DIR=./data

# 日志轮转配置
LOG_ROTATE_DAYS=1
LOG_BACKUP_COUNT=30

# 数据保留天数（每日 00:30 自动清理）
RAW_CONTENT_RETENTION_DAYS=7
DAILY_STATS_RETENTION_DAYS=30
FEEDBACK_RETENTION_DAYS=30

# ============================================================================
# 🌐 默认信息源（新用户注册时使用）
# ============================================================================
# Twitter 聚合源（来自 RSS.app 的打包订阅）
DEFAULT_TWITTER_SOURCES=Twitter Bundle 1|https://rss.app/feeds/yKWqoQhp8f7hpSI0.xml,Twitter Bundle 2|https://rss.app/feeds/RybG6gSijLjK3Yn6.xml,Twitter Bundle 3|https://rss.app/feeds/1eJwBA9j6nznaf3N.xml

# Web3 新闻网站 RSS 源（已验证可用）
DEFAULT_WEBSITE_SOURCES=Cointelegraph|https://cointelegraph.com/rss,CoinDesk|https://www.coindesk.com/arc/outboundfeeds/rss/,The Block Beats|https://api.theblockbeats.news/v1/open-api/home-xml,TechFlow Post|https://techflowpost.substack.com/feed,TechFlow 快讯|https://www.techflowpost.com/api/client/common/rss.xml,DeFi Rate|https://defirate.com/feed,Event Horizon|https://nexteventhorizon.substack.com/feed,un.Block (吴说)|https://unblock256.substack.com/feed

# ============================================================================
# 🚀 Feature Flags
# ============================================================================
FEATURE_SOURCE_HEALTH=true
FEATURE_PAYMENT=false
FEATURE_GROUP_CHAT=true

# ============================================================================
# 🔧 其他配置
# ============================================================================
# 翻译 Temperature（0.0-1.0，低值更准确）
TRANSLATION_TEMPERATURE=0.1

# 频率限制：每用户每分钟最大交互次数（0=禁用）
RATE_LIMIT_PER_MINUTE=30

# 暂停推送开关（调试用，true=暂停所有定时推送）
PAUSE_PUSH=false

# ============================================================================
# 📖 LLM 切换示例
# ============================================================================
#
# 【Gemini（当前配置）】
#   LLM=gemini
#   GEMINI_API_KEY=AIzaSy...
#   GEMINI_MODEL=gemini-2.0-flash
#
# 【Kimi（月之暗面，国内可用）】
#   LLM=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=kimi-k2-thinking
#   OPENAI_API_URL=https://api.moonshot.cn/v1/chat/completions
#
# 【DeepSeek】
#   LLM=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=deepseek-chat
#   OPENAI_API_URL=https://api.deepseek.com/v1/chat/completions
