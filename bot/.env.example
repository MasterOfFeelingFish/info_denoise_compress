# Environment Configuration for Web3 Daily Digest

# ============ Gemini 3 Pro API Configuration ============
# Get your API key from: https://ai.google.dev/ (Click "Get API key")
GEMINI_API_KEY=AIzaSyApIzRHVeewtVE3PbyathntMwQdC3heX-8

# Optional: Custom Gemini API URL (for proxy or different region)
# Supports two formats:
#   1. Base URL only: https://your-proxy.com (path auto-appended)
#   2. Full URL: https://your-proxy.com/v1beta/models/gemini-3-pro:generateContent
# Example: GEMINI_API_URL=https://preprod-generativelanguage.googleapis.com
GEMINI_API_URL=https://preprod-generativelanguage.googleapis.com

# Model selection (default: gemini-3-pro-preview)
# Available: gemini-3-pro-preview, gemini-3-flash, gemini-2.5-pro, gemini-2.5-flash
GEMINI_MODEL=gemini-3-pro-preview

# Thinking level for reasoning (Gemini 3 Pro only)
# LOW = faster, less reasoning
# HIGH = slower, better reasoning (default)
GEMINI_THINKING_LEVEL=HIGH

# ============ Telegram Bot ============
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============ Push Schedule ============
# Beijing Time, 24-hour format
PUSH_HOUR=9
PUSH_MINUTE=0

# ============ Data Storage ============
DATA_DIR=./data

# ============ Logging ============
# 日志轮转间隔（天），默认1天
LOG_ROTATE_DAYS=1
# 日志备份保留数量，默认30个
LOG_BACKUP_COUNT=30

# ============ Data Retention ============
# 数据保留天数配置，超过后自动清理（每日00:30执行）
# 原始抓取内容保留天数，默认7天
RAW_CONTENT_RETENTION_DAYS=7
# 每日统计保留天数，默认30天
DAILY_STATS_RETENTION_DAYS=30
# 反馈记录保留天数，默认30天
FEEDBACK_RETENTION_DAYS=30

# ============ Digest Settings ============
# 每日精选条数范围，AI 根据内容质量在范围内决定
MIN_DIGEST_ITEMS=15
MAX_DIGEST_ITEMS=30

# ============ AI Chat Settings ============
# 对话上下文保留天数 (0=只用当天, 1=包含昨天, 2=包含前天)
CHAT_CONTEXT_DAYS=1

# ============ Default Sources (for new users) ============
# Format 1: JSON (complete control)
# DEFAULT_SOURCES={"twitter": {"@VitalikButerin": "https://rss.app/xxx"}, "websites": {"The Block": "https://theblock.co/rss.xml"}}

# Format 2: Simple comma-separated (easier to edit)
# Twitter: @handle|rss_url (RSS.app or similar service required)
# DEFAULT_TWITTER_SOURCES=@VitalikButerin|https://rss.app/feeds/xxx

# Websites: Name|rss_url
DEFAULT_WEBSITE_SOURCES=The Block|https://www.theblock.co/rss.xml,CoinDesk|https://www.coindesk.com/arc/outboundfeeds/rss/,Decrypt|https://decrypt.co/feed,Cointelegraph|https://cointelegraph.com/rss
