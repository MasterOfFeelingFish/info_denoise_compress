# Environment Configuration for Web3 Daily Digest

# ============================================================================
# 🚀 LLM 配置 - 一键切换
# ============================================================================
# 可选值: gemini | openai
LLM=gemini

# --- Gemini 配置 ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-pro-preview
GEMINI_API_URL=
GEMINI_THINKING_LEVEL=HIGH

# --- OpenAI 配置（兼容 Kimi、DeepSeek 等）---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_API_URL=

# ============================================================================
# 🤖 Telegram Bot 配置
# ============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================================================
# ⏰ 推送时间配置
# ============================================================================
PUSH_HOUR=9
PUSH_MINUTE=0

# ============================================================================
# 📊 数据管理配置
# ============================================================================
DATA_DIR=./data

# 日志轮转配置
LOG_ROTATE_DAYS=1
LOG_BACKUP_COUNT=30

# 数据保留天数（每日 00:30 自动清理）
RAW_CONTENT_RETENTION_DAYS=7
DAILY_STATS_RETENTION_DAYS=30
FEEDBACK_RETENTION_DAYS=30

# ============================================================================
# 📰 简报配置
# ============================================================================
# AI 每日精选条数范围
MIN_DIGEST_ITEMS=15
MAX_DIGEST_ITEMS=30

# 并发处理用户数（推送简报时并发处理多少用户）
# 范围: 1-50，推荐 10
CONCURRENT_USERS=10

# ============================================================================
# 🌐 默认信息源（新用户注册时使用）
# ============================================================================
# Twitter 聚合源（来自 RSS.app 的打包订阅）
DEFAULT_TWITTER_SOURCES=Twitter Bundle 1|https://rss.app/feeds/G6dip9YSp1NzQMls.xml,Twitter Bundle 2|https://rss.app/feeds/HVg722x6SI7tChWQ.xml

# Web3 新闻网站 RSS 源（已验证可用）
DEFAULT_WEBSITE_SOURCES=Cointelegraph|https://cointelegraph.com/rss,CoinDesk|https://www.coindesk.com/arc/outboundfeeds/rss/,The Block Beats|https://api.theblockbeats.news/v1/open-api/home-xml,TechFlow Post|https://techflowpost.substack.com/feed,DeFi Rate|https://defirate.com/feed,Prediction News|https://predictionnews.com/rss/,Event Horizon|https://nexteventhorizon.substack.com/feed,un.Block (吴说)|https://unblock256.substack.com/feed

# ============================================================================
# 📖 使用示例
# ============================================================================
#
# 【使用 Gemini (当前配置)】
#   LLM=gemini
#   GEMINI_API_KEY=AIzaSy...
#   GEMINI_MODEL=gemini-3-pro-preview
#   GEMINI_API_URL=https://preprod-generativelanguage.googleapis.com
#   GEMINI_THINKING_LEVEL=HIGH
#
# 【切换到 OpenAI GPT-4o】
#   LLM=openai
#   OPENAI_API_KEY=sk-proj-...
#   OPENAI_MODEL=gpt-4o
#   OPENAI_API_URL=
#
# 【切换到 Kimi (月之暗面)】
#   LLM=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=moonshot-v1-8k
#   OPENAI_API_URL=https://api.moonshot.cn/v1/chat/completions
#
# 【切换到 DeepSeek】
#   LLM=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=deepseek-chat
#   OPENAI_API_URL=https://api.deepseek.com/v1/chat/completions
#
# ============================================================================
